# Copy this file to .env and adjust the values for your machine.

# Root directory holding all project data (raw inputs under $DATA_DIR/input,
# processed outputs under $DATA_DIR/output).
DATA_DIR="/path/to/project-data"

# JDK for Apache Spark/Sedona. Either an absolute path to a JDK installation,
# or a directory name relative to $DATA_DIR/../.jdk (see src/utils/install_jdk.py).
JDK_HOME="jdk-17.0.2"

# Google Earth Engine cloud project used for the spectral indices step.
GEE_PROJECT_NAME="your-gee-project"

# GEE asset containing the Output Area boundaries used to clip spectral images.
# Upload the ONS Output Areas boundaries to your own GEE project and point this
# at the resulting asset.
GEE_BOUNDARIES_ASSET="projects/your-gee-project/assets/output_areas_boundaries"
